---
import { Image } from 'astro:assets';
import type { ImageInput } from '../types';

type Props = ImageInput & {
    class?: string;
    width?: number;
    height?: number;
    sizes?: string;
    widths?: number[];
    format?: 'avif' | 'webp' | 'png' | 'jpg' | 'jpeg';
    loading?: 'lazy' | 'eager';
    fetchpriority?: 'high' | 'low' | 'auto';
    decoding?: 'async' | 'sync' | 'auto';
    objectPosition?: string;
};

const { src, alt = "", class: className, loading = "lazy", fetchpriority, decoding = "async", objectPosition, ...rest } = Astro.props as Props;

// 将 objectPosition 转换为 Tailwind class
const objectPositionClass = objectPosition ? `object-[${objectPosition}]` : 'object-center';
---

{
    typeof src === 'string' ? (
        <img class={`object-cover ${objectPositionClass} ${className}`} src={src} alt={alt} loading={loading} decoding={decoding} />
    ) : (
        <Image class={`object-cover ${objectPositionClass} ${className}`} src={src} alt={alt} loading={loading} fetchpriority={fetchpriority} decoding={decoding} {...rest} />
    )
}
