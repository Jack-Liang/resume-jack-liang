---
import { getCollection } from 'astro:content';
import Header from '../../components/Header.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

interface NoteItem {
    date: Date;
    content: string;
}

const notesData = await getCollection('notes');

// 解析所有随想
const allNotes: NoteItem[] = [];

for (const note of notesData) {
    const blocks = (note.body ?? '').split(/\n---\n/).filter(block => block.trim());
    
    for (const block of blocks) {
        const lines = block.trim().split('\n');
        const dateMatch = lines[0].match(/^(\d{4})\.(\d{2})\.(\d{2})/);
        
        if (dateMatch) {
            const [, year, month, day] = dateMatch;
            const date = new Date(parseInt(year), parseInt(month) - 1, parseInt(day));
            const content = lines.slice(1).join('\n').trim();
            
            if (content) {
                allNotes.push({ date, content });
            }
        }
    }
}

// 按日期倒序排序
allNotes.sort((a, b) => b.date.getTime() - a.date.getTime());

function formatDate(date: Date) {
    return date.toLocaleDateString('zh-CN', {
        month: 'long',
        day: 'numeric'
    });
}
---

<BaseLayout title="随想 | Jack Liang" description="Jack Liang 的简短随想">
    <div class="relative border-b border-slate-100 dark:border-slate-700 bg-slate-50 dark:bg-slate-800/50" slot="header">
        <Header class="relative" />
    </div>

    <main class="py-12 grow sm:py-16">
        <div class="px-4 mb-12 sm:mb-16 sm:px-8">
            <div class="max-w-3xl mx-auto mb-8 sm:mb-12">
                <h1 class="after:bg-primary text-3xl font-bold text-slate-900 dark:text-white sm:text-4xl after:mt-4 after:block after:h-px after:w-16 after:content-['']">
                    随想
                </h1>
                <p class="mt-4 text-slate-500 dark:text-slate-400">生活不是我们活过的日子，而是我们记住的日子。——《活着为了讲述》</p>
                <img
                    src="https://pexels.kiksoft.net/api/random?orientation=landscape"
                    alt="随想封面图"
                    class="mt-6 w-full max-h-48 h-auto object-cover rounded-xl border border-slate-200 dark:border-slate-700"
                    loading="lazy"
                />
            </div>

            <div class="max-w-3xl mx-auto">
                <div class="relative">
                    <div class="absolute left-8 top-0 bottom-0 w-px bg-slate-200 dark:bg-slate-700 sm:left-10"></div>
                    
                    <div class="space-y-6">
                        {allNotes.map((note, index) => {
                            const year = note.date.getFullYear();
                            const prevYear = index > 0 ? allNotes[index - 1].date.getFullYear() : null;
                            const showYear = year !== prevYear;
                            return (
                                <>
                                    {showYear && (
                                        <div class="relative pl-20 sm:pl-24">
                                            <div class="absolute left-8 top-2.5 -translate-x-1/2 w-3 h-3 rounded-full bg-primary sm:left-10"></div>
                                            <h2 class="text-2xl font-bold text-slate-900 dark:text-white sm:text-3xl">
                                                {year}
                                            </h2>
                                        </div>
                                    )}
                                    <article class="relative pl-20 sm:pl-24">
                                        <div class="absolute left-8 top-3 w-4 h-4 -translate-x-1/2 rounded-full border-4 border-white bg-primary sm:left-10"></div>
                                        <div class="bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 p-5 hover:border-slate-300 dark:hover:border-slate-600 transition-colors">
                                            <time class="text-sm text-slate-400 dark:text-slate-500">{formatDate(note.date)}</time>
                                            <div class="mt-2 text-slate-700 dark:text-slate-300 leading-relaxed whitespace-pre-line">
                                                {note.content}
                                            </div>
                                        </div>
                                    </article>
                                </>
                            );
                        })}
                    </div>
                </div>
            </div>
        </div>
    </main>
</BaseLayout>
