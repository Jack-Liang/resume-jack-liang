---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostPreview from '../../../components/PostPreview.astro';
import { sortPostsByDateDesc, sortPostsByDateAsc } from '../../../utils/post-utils';

export async function getStaticPaths() {
    const posts = (await getCollection('blog')).filter((post) => !post.data.draft);
    const allTags = [...new Set(posts.flatMap((post) => post.data.tags ?? []))];

    return allTags.map((tag) => ({
        params: { tag },
        props: {
            tag,
            posts: posts
                .filter((post) => post.data.tags?.includes(tag))
                .sort(sortPostsByDateDesc)
        }
    }));
}

const { tag, posts } = Astro.props;
const postsData = posts.map(post => ({
    id: post.id,
    data: post.data,
    body: post.body,
    collection: post.collection,
    slug: post.slug
}));
---

<BaseLayout title={`标签: ${tag}`} description={`所有包含 "${tag}" 标签的文章`}>
    <main class="px-4 py-12 grow sm:px-8 sm:py-16">
        <div class="max-w-3xl mx-auto">
            <header class="mb-12 sm:mb-16">
                <h1 class="text-3xl font-bold text-slate-900 sm:text-4xl">
                    标签: <span class="text-primary">{tag}</span>
                </h1>
                <div class="mt-2 flex items-center justify-between">
                    <p class="text-slate-500">共 {posts.length} 篇文章</p>
                    <div class="flex items-center gap-2">
                        <span class="text-sm text-slate-400">排序:</span>
                        <button
                            data-sort="desc"
                            class="sort-btn px-3 py-1 text-sm rounded-full transition-colors bg-primary text-white"
                        >
                            最新
                        </button>
                        <button
                            data-sort="asc"
                            class="sort-btn px-3 py-1 text-sm rounded-full transition-colors bg-slate-100 text-slate-600 hover:bg-slate-200"
                        >
                            最早
                        </button>
                    </div>
                </div>
            </header>
            <div id="posts-container" data-posts={JSON.stringify(postsData)} data-sort="desc">
            </div>
        </div>
    </main>
</BaseLayout>

<script define:vars={{ postsData, tag }}>
    function renderPosts(posts, container) {
        const currentSort = container.dataset.sort;
        const sorted = currentSort === 'asc'
            ? [...posts].sort((a, b) => new Date(a.data.publishDate) - new Date(b.data.publishDate))
            : [...posts].sort((a, b) => new Date(b.data.publishDate) - new Date(a.data.publishDate));

        container.innerHTML = sorted.map(post => `
            <article class="mb-12 post-card sm:mb-16">
                <header class="post-card-header">
                    <div class="mb-2 text-sm tracking-wider uppercase text-slate-500">
                        <time datetime="${post.data.publishDate}">${new Date(post.data.publishDate).toLocaleDateString('zh-CN')}</time>
                    </div>
                    <h2 class="text-3xl font-bold text-slate-900"><a href="/blog/${post.id}/">${post.data.title}</a></h2>
                    ${post.data.tags && post.data.tags.length > 0 ? `
                        <div class="mt-2 flex flex-wrap gap-2">
                            ${post.data.tags.map(t => `
                                <a href="/blog/tag/${encodeURIComponent(t)}"
                                   class="px-2 py-0.5 text-xs font-medium rounded-full bg-slate-100 text-slate-500 hover:bg-primary hover:text-white transition-colors">
                                    ${t}
                                </a>
                            `).join('')}
                        </div>
                    ` : ''}
                </header>
                ${post.data.featureImage?.src ? `
                    <figure class="mt-6 mb-6 post-card-thumbnail xl:mt-7 xl:mb-0">
                        <a href="/blog/${post.id}/">
                            <img src="${post.data.featureImage.src}" alt="${post.data.featureImage.alt || ''}"
                                 class="w-full rounded-md" loading="lazy" />
                        </a>
                    </figure>
                ` : ''}
                ${post.data.excerpt ? `
                    <div class="mt-4 post-card-content">
                        <div class="prose prose-slate sm:prose-lg max-w-none">${post.data.excerpt}</div>
                    </div>
                ` : ''}
            </article>
        `).join('');
    }

    function init() {
        const container = document.getElementById('posts-container');
        const buttons = document.querySelectorAll('.sort-btn');

        renderPosts(postsData, container);

        buttons.forEach(btn => {
            btn.addEventListener('click', () => {
                const sort = btn.dataset.sort;
                container.dataset.sort = sort;

                buttons.forEach(b => {
                    if (b.dataset.sort === sort) {
                        b.classList.add('bg-primary', 'text-white');
                        b.classList.remove('bg-slate-100', 'text-slate-600');
                    } else {
                        b.classList.remove('bg-primary', 'text-white');
                        b.classList.add('bg-slate-100', 'text-slate-600');
                    }
                });

                renderPosts(postsData, container);

                // Update URL without reload
                const url = new URL(window.location.href);
                url.searchParams.set('sort', sort);
                history.replaceState(null, '', url);
            });
        });
    }

    init();
    document.addEventListener('astro:after-swap', init);
</script>

<style>
    @reference "tailwindcss";
    @media (min-width: 1280px) {
        .post-card-header {
            grid-area: header;
        }
        .post-card-content {
            grid-area: content;
        }
        .post-card-thumbnail {
            grid-area: thumbnail;
        }
        .post-card {
            @apply grid gap-x-8;
            grid-template-rows: min-content 1fr;
            grid-template-columns: 1fr 768px 1fr;
            grid-template-areas:
                'thumbnail header'
                'thumbnail content';
        }
    }
</style>